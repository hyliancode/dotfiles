#!/bin/bash

chkcmd jq selopt || exit 1

catch() { echo "${1}"; exit 1; }

[[ -f "${HOME}/.color_schemes.json" ]] || catch "Color schemes file not found at ${HOME}/.color_schemes.json"
readarray -t options < <(jq -r 'del(.comment) | keys[]' "${HOME}/.color_schemes.json" || true)
[[ ${#options[@]} -eq 0 ]] && catch "No color schemes found in ${HOME}/.color_schemes.json"
options+=("quit")

scheme="$(selopt -rofi "Select a color scheme: " "${options[@]}" || true)"
[[ -z "${scheme}" ]] && catch "No color scheme selected. Exiting."
[[ "${scheme}" == "quit" ]] && echo "Exiting without changes." && exit 0

readarray -t colors < <(jq -r ".\"${scheme}\"[]" "${HOME}/.color_schemes.json" || true)
[[ ${#colors[@]} -eq 0 ]] && catch "No colors found for scheme '${scheme}'"
[[ ${#colors[@]} -ne 16 ]] && catch "Expected 16 colors for scheme '${scheme}', found ${#colors[@]}"

for i in "${!colors[@]}"; do
    printf "\e]4;%d;%s\a" "${i}" "${colors[$i]}"
done

printf "\e]10;%s\a" "${colors[7]}" # Foreground
printf "\e]11;%s\a" "${colors[8]}" # Background
printf "\e]12;%s\a" "${colors[7]}" # Cursor

{ chkcmd "neofetch" && neofetch; } || { chkcmd "fastfetch" && fastfetch; }