#!/bin/bash

catch() { echo "${1}"; exit 1; }

if systemctl is-active --quiet mpd; then
    sudo systemctl stop mpd \
	|| catch "Failed to stop system level 'mpd'"

    sudo systemctl disable mpd \
	|| catch "Failed to disable system level 'mpd'"
fi

if [[ -S /run/mpd/socket ]]; then
    sudo rm -f /run/mpd/socket \
	|| catch "Failed to remove '/run/mpd/socket'"
fi

if systemctl --user is-active --quiet mpd; then
    echo "User-level MPD is running."
	exit 0
else
	systemctl --user enable --now mpd.socket \
	|| catch "Failed to enable user 'mpd'"

	systemctl --user restart mpd.socket \
	|| catch "Failed to restart user 'mpd'"
fi
