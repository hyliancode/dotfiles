#!/bin/bash

check_command() {
    if [[ "${#}" = 0 ]]; then
        echo "No command provided to check"
        return 1
    fi
    for command in "${@}"; do
        ! command -v "${command}" 1>/dev/null && commands_not_found+=("${command}")
    done
    if (( "${#commands_not_found[@]}" > 0 )); then
        echo "These required commands were not found:"
        printf "\e[31m> %s\e[0m\n" "${commands_not_found[@]}"
    fi
    return "${#commands_not_found[@]}"
}

check_command "${@}"