#!/bin/bash

_common_cleanup() {
    echo "Emptying '/tmp'"
    sudo gio trash -f /tmp/*
    gio trash -f /tmp/*
    
    echo "Emptying trash"
    sudo gio trash -f --empty
    gio trash -f --empty

    echo "Removing broken symlinks"
    find "${HOME}" -xtype l -print -delete

    echo "Syncing"
    sync
}

_debian_cleanup() {
    _common_cleanup
}

_arch_cleanup() {
    _common_cleanup
}

case "$(grep -siE "^ID_LIKE=|^ID=" /etc/os-release)" in
    *debian* ) _debian_cleanup ;;
    *arch* ) _arch_cleanup ;;
    * ) echo "Unsupported distribution" ;;
esac